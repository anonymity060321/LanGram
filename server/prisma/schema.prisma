generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum AccountType {
  EMAIL
  GUEST

  @@map("account_type")
}

enum UserStatus {
  ACTIVE
  DISABLED

  @@map("user_status")
}

enum EmailVerificationPurpose {
  REGISTER
  LOGIN
  PASSWORD_RESET

  @@map("email_verification_purpose")
}

enum AuthCaptchaPurpose {
  LOGIN

  @@map("auth_captcha_purpose")
}

enum FriendRequestStatus {
  PENDING
  ACCEPTED
  REJECTED

  @@map("friend_request_status")
}

enum ConversationType {
  DIRECT
  GROUP

  @@map("conversation_type")
}

enum ConversationMemberRole {
  OWNER
  MEMBER

  @@map("conversation_member_role")
}

enum MessageType {
  TEXT
  IMAGE
  FILE

  @@map("message_type")
}

enum FileKind {
  IMAGE
  FILE

  @@map("file_kind")
}

enum FileStatus {
  UPLOADED
  ATTACHED
  DELETED

  @@map("file_status")
}

enum MessageStatus {
  SENT
  DELIVERED
  READ
  RECALLED

  @@map("message_status")
}

model User {
  id           String      @id @default(uuid()) @db.Uuid
  email        String?     @unique
  passwordHash String?     @map("password_hash")
  displayName  String      @map("display_name")
  statusMessage     String?   @map("status_message")
  avatarStoragePath String?   @map("avatar_storage_path")
  avatarMimeType    String?   @map("avatar_mime_type")
  avatarUpdatedAt   DateTime? @map("avatar_updated_at")
  accountType  AccountType @map("account_type")
  isTemporary  Boolean     @default(false) @map("is_temporary")
  status       UserStatus  @default(ACTIVE)
  lastSeenAt   DateTime?   @map("last_seen_at")
  createdAt    DateTime    @default(now()) @map("created_at")
  updatedAt    DateTime    @updatedAt @map("updated_at")

  devices                Device[]
  sessions               Session[]
  uploadedFiles          FileAsset[]          @relation("FileAssetUploader")
  loginLogs              LoginLog[]
  pairingCodes           FriendPairingCode[]  @relation("PairingCodeOwner")
  sentFriendRequests     FriendRequest[]      @relation("FriendRequestRequester")
  receivedFriendRequests FriendRequest[]      @relation("FriendRequestAddressee")
  friendshipsAsUserA     Friendship[]         @relation("FriendshipUserA")
  friendshipsAsUserB     Friendship[]         @relation("FriendshipUserB")
  conversationMembers    ConversationMember[]
  createdConversations   Conversation[]       @relation("ConversationCreator")
  sentMessages           Message[]            @relation("MessageSender")
  messageDeliveries      MessageDelivery[]    @relation("MessageDeliveryReceiver")

  @@map("users")
}

model Device {
  id               String    @id @default(uuid()) @db.Uuid
  userId           String    @map("user_id") @db.Uuid
  deviceIdentifier String    @map("device_identifier")
  name             String?
  platform         String?
  lastSeenAt       DateTime? @map("last_seen_at")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  user     User      @relation(fields: [userId], references: [id])
  sessions Session[]

  @@unique([userId, deviceIdentifier])
  @@map("devices")
}

model Session {
  id               String    @id @default(uuid()) @db.Uuid
  userId           String    @map("user_id") @db.Uuid
  deviceId         String?   @map("device_id") @db.Uuid
  refreshTokenHash String    @map("refresh_token_hash")
  expiresAt        DateTime  @map("expires_at")
  revokedAt        DateTime? @map("revoked_at")
  lastUsedAt       DateTime  @default(now()) @map("last_used_at")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  user   User    @relation(fields: [userId], references: [id])
  device Device? @relation(fields: [deviceId], references: [id])

  @@index([userId, revokedAt])
  @@map("sessions")
}

model EmailVerificationCode {
  id         String                   @id @default(uuid()) @db.Uuid
  email      String
  codeHash   String                   @map("code_hash")
  purpose    EmailVerificationPurpose
  expiresAt  DateTime                 @map("expires_at")
  consumedAt DateTime?                @map("consumed_at")
  createdAt  DateTime                 @default(now()) @map("created_at")

  @@index([email, purpose, createdAt])
  @@map("email_verification_codes")
}

model AuthCaptchaChallenge {
  id           String             @id @default(uuid()) @db.Uuid
  answerHash   String             @map("answer_hash")
  purpose      AuthCaptchaPurpose
  expiresAt    DateTime           @map("expires_at")
  consumedAt   DateTime?          @map("consumed_at")
  attemptCount Int                @default(0) @map("attempt_count")
  createdAt    DateTime           @default(now()) @map("created_at")

  @@index([purpose, createdAt])
  @@index([expiresAt, consumedAt])
  @@map("auth_captcha_challenges")
}

model LoginLog {
  id               String   @id @default(uuid()) @db.Uuid
  userId           String?  @map("user_id") @db.Uuid
  email            String?
  deviceIdentifier String?  @map("device_identifier")
  success          Boolean
  reason           String?
  ipAddress        String?  @map("ip_address")
  userAgent        String?  @map("user_agent")
  createdAt        DateTime @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id])

  @@index([userId, createdAt])
  @@index([email, createdAt])
  @@map("login_logs")
}

model FriendPairingCode {
  id         String    @id @default(uuid()) @db.Uuid
  userId     String    @map("user_id") @db.Uuid
  codeHash   String    @map("code_hash")
  expiresAt  DateTime  @map("expires_at")
  consumedAt DateTime? @map("consumed_at")
  createdAt  DateTime  @default(now()) @map("created_at")

  user User @relation("PairingCodeOwner", fields: [userId], references: [id])

  @@index([userId, createdAt])
  @@index([expiresAt, consumedAt])
  @@map("friend_pairing_codes")
}

model FriendRequest {
  id          String              @id @default(uuid()) @db.Uuid
  requesterId String              @map("requester_id") @db.Uuid
  addresseeId String              @map("addressee_id") @db.Uuid
  status      FriendRequestStatus @default(PENDING)
  respondedAt DateTime?           @map("responded_at")
  createdAt   DateTime            @default(now()) @map("created_at")
  updatedAt   DateTime            @updatedAt @map("updated_at")

  requester  User        @relation("FriendRequestRequester", fields: [requesterId], references: [id])
  addressee  User        @relation("FriendRequestAddressee", fields: [addresseeId], references: [id])
  friendship Friendship?

  @@unique([requesterId, addresseeId])
  @@index([addresseeId, status, createdAt])
  @@index([requesterId, status, createdAt])
  @@map("friend_requests")
}

model Friendship {
  id                   String   @id @default(uuid()) @db.Uuid
  userAId              String   @map("user_a_id") @db.Uuid
  userBId              String   @map("user_b_id") @db.Uuid
  createdFromRequestId String?  @unique @map("created_from_request_id") @db.Uuid
  createdAt            DateTime @default(now()) @map("created_at")

  userA              User          @relation("FriendshipUserA", fields: [userAId], references: [id])
  userB              User          @relation("FriendshipUserB", fields: [userBId], references: [id])
  createdFromRequest FriendRequest? @relation(fields: [createdFromRequestId], references: [id], onDelete: SetNull)

  @@unique([userAId, userBId])
  @@index([userAId])
  @@index([userBId])
  @@map("friendships")
}

model Conversation {
  id              String           @id @default(uuid()) @db.Uuid
  type            ConversationType
  title           String?
  intro           String?          @db.VarChar(500)
  avatarUrl       String?          @map("avatar_url") @db.VarChar(1024)
  announcement    String?          @db.VarChar(2000)
  createdByUserId String?          @map("created_by_user_id") @db.Uuid
  directUserAId   String?          @map("direct_user_a_id") @db.Uuid
  directUserBId   String?          @map("direct_user_b_id") @db.Uuid
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")

  createdBy User?                @relation("ConversationCreator", fields: [createdByUserId], references: [id], onDelete: SetNull)
  members   ConversationMember[]
  messages  Message[]
  files     FileAsset[]

  @@unique([type, directUserAId, directUserBId])
  @@index([type])
  @@index([createdByUserId])
  @@map("conversations")
}

model ConversationMember {
  id                String                 @id @default(uuid()) @db.Uuid
  conversationId    String                 @map("conversation_id") @db.Uuid
  userId            String                 @map("user_id") @db.Uuid
  role              ConversationMemberRole @default(MEMBER)
  groupNickname     String?                @map("group_nickname")
  groupRemark       String?                @map("group_remark")
  lastReadMessageId String?                @map("last_read_message_id") @db.Uuid
  lastReadAt        DateTime?              @map("last_read_at")
  joinedAt          DateTime               @default(now()) @map("joined_at")
  leftAt            DateTime?              @map("left_at")
  createdAt         DateTime               @default(now()) @map("created_at")

  conversation Conversation @relation(fields: [conversationId], references: [id])
  user         User         @relation(fields: [userId], references: [id])

  @@unique([conversationId, userId])
  @@index([conversationId, leftAt])
  @@index([userId, leftAt])
  @@map("conversation_members")
}

model Message {
  id                String        @id @default(uuid()) @db.Uuid
  conversationId    String        @map("conversation_id") @db.Uuid
  senderId          String        @map("sender_id") @db.Uuid
  messageType       MessageType   @map("message_type")
  ciphertext        String
  encryptionVersion String        @map("encryption_version")
  nonce             String
  replyToMessageId  String?       @map("reply_to_message_id") @db.Uuid
  status            MessageStatus @default(SENT)
  editedAt          DateTime?     @map("edited_at")
  recalledAt        DateTime?     @map("recalled_at")
  createdAt         DateTime      @default(now()) @map("created_at")
  updatedAt         DateTime      @updatedAt @map("updated_at")

  conversation Conversation      @relation(fields: [conversationId], references: [id])
  sender       User              @relation("MessageSender", fields: [senderId], references: [id])
  deliveries   MessageDelivery[]
  fileAsset    FileAsset?

  @@index([conversationId, createdAt])
  @@index([senderId, createdAt])
  @@map("messages")
}

model FileAsset {
  id             String     @id @default(uuid()) @db.Uuid
  uploaderId     String     @map("uploader_id") @db.Uuid
  conversationId String     @map("conversation_id") @db.Uuid
  messageId      String?    @unique @map("message_id") @db.Uuid
  kind           FileKind
  originalName   String     @map("original_name")
  safeName       String     @map("safe_name")
  mimeType       String     @map("mime_type")
  sizeBytes      BigInt     @map("size_bytes")
  sha256         String
  storagePath    String     @map("storage_path")
  width          Int?
  height         Int?
  status         FileStatus @default(UPLOADED)
  createdAt      DateTime   @default(now()) @map("created_at")
  updatedAt      DateTime   @updatedAt @map("updated_at")
  deletedAt      DateTime?  @map("deleted_at")

  uploader     User         @relation("FileAssetUploader", fields: [uploaderId], references: [id])
  conversation Conversation @relation(fields: [conversationId], references: [id])
  message      Message?     @relation(fields: [messageId], references: [id])

  @@index([conversationId, createdAt])
  @@index([uploaderId, createdAt])
  @@index([status, createdAt])
  @@map("file_assets")
}

model MessageDelivery {
  id          String    @id @default(uuid()) @db.Uuid
  messageId   String    @map("message_id") @db.Uuid
  receiverId  String    @map("receiver_id") @db.Uuid
  deliveredAt DateTime? @map("delivered_at")
  readAt      DateTime? @map("read_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  message  Message @relation(fields: [messageId], references: [id])
  receiver User    @relation("MessageDeliveryReceiver", fields: [receiverId], references: [id])

  @@unique([messageId, receiverId])
  @@index([receiverId, deliveredAt])
  @@index([receiverId, readAt])
  @@map("message_deliveries")
}

model AppSetting {
  key       String   @id
  value     String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("app_settings")
}


